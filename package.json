{
  "type": "module",
  "name": "@rainbow-industries/rainbow-config",
  "version": "3.2.1",
  "description": "A YAML config file loader",
  "dependencies": {
    "typescript": "^5.8.3",
    "yaml": "^2.7.1"
  },
  "scripts": {
    "build": "node ./node_modules/.bin/tsc",
    "test": "node ./node_modules/.bin/tsc && node ./node_modules/.bin/section ./build/tests/**/*.test.js",
    "clean": "rm -r build"
  },
  "devDependencies": {
    "@tsconfig/node16": "^16.1.3",
    "@types/node": "^22.14.1",
    "eslint": "^9.24.0",
    "section-tests": "^5.0.18"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "keywords": [
    "config-loader",
    "config-file",
    "config",
    "yaml"
  ]
}
